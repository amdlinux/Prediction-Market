generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// A prediction market (e.g. "Will BTC exceed $100k?")
model Market {
  id          String   @id @default(cuid())
  title       String
  description String  @default("")
  category    String
  closingDate DateTime
  status      String   @default("OPEN")  // OPEN, HALTED,RESOLVED, VOIDED
  outcome     String?                     // YES or NO (null until resolved)
  createdAt   DateTime @default(now())

  yesShares Float   @default(0)                   // total YES shares
  noShares  Float   @default(0)                   // total NO shares

  liquidityB Float   @default(100)                   // total liquidity in the market (in dollars)
  positions   Position[]
  priceHistory PriceHistory[]
}

// A user's bet on a market
model Position {
  id         String   @id @default(cuid())
  userId     String                        // Clerk user ID
  marketId   String
  side       String                        // YES or NO
  quantity   Int
  priceCents Int      @default(50)         
  isPractice Boolean @default(false)          // price in cents (e.g. 75 for $0.75)
  createdAt  DateTime @default(now())

  market     Market   @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId,isPractice])             // one position per user per market
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique                        // Clerk user ID
  cashbalanceCents Int    @default(0)        
  reservedCents Int    @default(0)      // balance in cents (e.g. $100.00)
  practiceBalanceCents    Int      @default(100000)  // $1,000 in cents
  practiceReservedCents   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String                        // Clerk user ID
  type       String                        // DEPOSIT, WITHDRAWAL, BET, WIN, LOSS
  amountCents Int                           // amount in cents (e.g. $100.00)
  createdAt  DateTime @default(now())
  description String
}

model PriceHistory {
  id String @id @default(cuid())
  marketId String
  yesPricePct Float
  createdAt DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id])
}

model SettledPosition {
  id              String   @id @default(cuid())
  userId          String
  marketId        String
  marketTitle     String   // store the title since the market may be deleted later
  side            String
  quantity        Int
  entryPriceCents Int      // what they paid per contract
  exitPriceCents  Int      // what they received per contract (100 if won, entryPrice if lost)
  realizedPnLCents Int     // net profit/loss in cents (can be negative)
  settledAt       DateTime @default(now())
}

model PortfolioSnapshot {
  id String @id @default(uuid())
  userId String
  valueCents Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}


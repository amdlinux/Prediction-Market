generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// A prediction market (e.g. "Will BTC exceed $100k?")
model Market {
  id          String   @id @default(cuid())
  title       String
  category    String
  closingDate DateTime
  status      String   @default("OPEN")  // OPEN, RESOLVED, VOIDED
  outcome     String?                     // YES or NO (null until resolved)
  createdAt   DateTime @default(now())

  positions   Position[]
}

// A user's bet on a market
model Position {
  id         String   @id @default(cuid())
  userId     String                        // Clerk user ID
  marketId   String
  side       String                        // YES or NO
  quantity   Int
  priceCents Int      @default(50)                   // price in cents (e.g. 75 for $0.75)
  createdAt  DateTime @default(now())

  market     Market   @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId])             // one position per user per market
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique                        // Clerk user ID
  cashbalanceCents Int    @default(0)        
  reservedCents Int    @default(0)      // balance in cents (e.g. $100.00)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String                        // Clerk user ID
  type       String                        // DEPOSIT, WITHDRAWAL, BET, WIN, LOSS
  amountCents Int                           // amount in cents (e.g. $100.00)
  createdAt  DateTime @default(now())
  description String
}